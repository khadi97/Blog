<!-- ! + enter -->
<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
    <%- include('partials/head.ejs') %> 
</head>
<body>
    <%- include('partials/header.ejs') %> 
    <div class="container">
        <div class="main">
            <div class="categories">
                <h3>Жанры</h3>
                <%
                    genres.forEach((genre) => {
                %>
                
                    <a href=''><%=genre.name%></a>
                
                <%
                    })
                %>
            </div>
            <div class="main-content">
                <h3>Профиль</h3>
                <div class="profile">
                    <div class="profile-img">
                        <img src="/images/profile.png" alt="profile">
                    </div>
                    <div class="profile-info">
                        <p><span>Полное имя: </span><%=user.full_name%></p>
                        <p><span>E-mail: </span><%=user.email%></p>
                        <%
                            if(loginUser.id == user.id){
                        %>
                            <a class="edit-btn">Редактировать профиль</a>
                            <a href='/api/signout' class="logout-btn">Выход</a>
                        <%
                            }
                        %>
                       
                    </div>
                </div>
                <h3>Сохраненные фильмы</h3>

                <div class="main-card">
                    <div class="card-left">
                        <div class="film-img">
                            <img src="/images/films/film1.webp" alt="film1">
                        </div>
                        <div class="film-info">
                            <a href="">Все везде и сразу</a>
                            <a href="">Everything Averywere All at Once, 2021, 139мин</a>
                            <a href="">США, Фантастика</a>
                            <button class="film-btn">
                                <img src="/images/icons/play.svg" alt="play">
                                Смотреть
                            </button>
                        </div>
                    </div>
                    <div class="card-right">
                        <div class="film-rate">
                            <p>7.3</p>
                        </div>
                        <button class="film-btn">
                            <img src="/images/icons/save.svg" alt="save">
                            Буду смотреть
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>